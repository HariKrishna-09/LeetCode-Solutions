class Solution {
    public boolean isValid(String s) {
        char stack[]=new char[s.length()];
        int top=-1;
        for(int i=0;i<s.length();i++){
            if(s.charAt(i)=='('||s.charAt(i)=='{'||s.charAt(i)=='[')
            {
                stack[++top]=s.charAt(i);
            }
            else {
                if (top==-1){
                    return false;
                }
                char tc=stack[top--];
                if(s.charAt(i)==')' && tc!='(' || s.charAt(i)=='}' && tc!='{' || s.charAt(i)==']' && tc!='[')    return false;
            }
        }
        return top==-1;
    }
}
