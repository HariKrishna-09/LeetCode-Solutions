class Solution {
    public int getMinDistance(int[] nums, int target, int start) {
        int x=nums.length;
        int res=x;
        for(int i=0;i<x;i++){
            if(nums[i]==target){
                int dis=Math.abs(i-start);;
                res=Math.min(res,dis);

            }
        }
        return res;
    }
}
